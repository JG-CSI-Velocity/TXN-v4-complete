# Newest cohort activation
newest = lc_full[lc_full['acct_age_band'] == '1-90d']
if len(newest) > 0:
    n = newest.iloc[0]
    print(f"  1. Newest accounts (1-90d): {n['account_count']:,.0f} accounts, "
          f"median {n['median_days_to_first']:.0f} days to first transaction")

# Most active band
most_active = lc_full.loc[lc_full['avg_txns'].idxmax()]
print(f"  2. Most active band: {most_active['acct_age_band']} "
      f"({most_active['avg_txns']:.1f} avg txns/account)")

# Highest spend band
highest_spend = lc_full.loc[lc_full['avg_oddd_spend'].idxmax()]
print(f"  3. Highest spend band: {highest_spend['acct_age_band']} "
      f"(${highest_spend['avg_oddd_spend']:,.0f} avg ODDD spend)")

# New account risk
new_bands = lc_full[lc_full['acct_age_band'].isin(['1-90d', '91-180d', '181-365d'])]
if len(new_bands) > 0:
    new_low_pct = lifecycle_matched[
        lifecycle_matched['acct_age_band'].isin(['1-90d', '91-180d', '181-365d']) &
        (lifecycle_matched['spend_tier'] == 'Low')
    ].shape[0]
    new_total = lifecycle_matched[
        lifecycle_matched['acct_age_band'].isin(['1-90d', '91-180d', '181-365d'])
    ].shape[0]
    if new_total > 0:
        pct_low = new_low_pct / new_total * 100
        print(f"  4. New accounts (< 1yr) in Low spend tier: {pct_low:.0f}% "
              f"-- onboarding engagement opportunity")

# Overall median activation
overall_median = lifecycle_matched['days_to_first_txn'].median()
