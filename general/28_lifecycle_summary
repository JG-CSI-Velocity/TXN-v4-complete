lc_table.columns = ['Account Age', 'Accounts', 'Avg Txns', 'Med Days to 1st Txn',
                     'Avg ODDD Spend', 'Avg Txn Spend', '% Very High']

styled = (
    lc_table.style
    .hide(axis='index')
    .format({
        'Accounts': '{:,.0f}',
        'Avg Txns': '{:.1f}',
        'Med Days to 1st Txn': '{:.0f}',
        'Avg ODDD Spend': '${:,.0f}',
        'Avg Txn Spend': '${:,.0f}',
        '% Very High': '{:.1f}%',
    })
    .set_properties(**{
        'font-size': '14px',
        'font-weight': 'bold',
        'text-align': 'center',
        'border': '1px solid #E9ECEF',
        'padding': '8px 12px',
    })
    .set_table_styles([
        {'selector': 'th', 'props': [
            ('background-color', GEN_COLORS['primary']),
            ('color', 'white'),
            ('font-size', '15px'),
