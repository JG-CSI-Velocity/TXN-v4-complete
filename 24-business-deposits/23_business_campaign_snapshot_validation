# ===========================================================================
# BUSINESS DEPOSITS: Campaign-Snapshot DID Validation
# ===========================================================================
# Mirror of Section 23 cell 23 for business accounts.
# Snapshot-based DID only (no MTD). Amount + Count for confirmation.
#
# Data: deposits_business_df + ZAccounts snapshots

import matplotlib.pyplot as plt
import matplotlib.ticker as mticker
import numpy as np

_df = deposits_business_df.copy()

if len(_df) < _MIN_ACCOUNTS:
    print(f"    23 Skipped: {len(_df)} business accounts (below {_MIN_ACCOUNTS} threshold)")
elif not HAS_CAMPAIGN_DATA:
    print("    23 Skipped: no campaign data")
elif not ZA_HAS_MULTIPLE:
    print("    23 Skipped: requires 2+ ZAccounts snapshots")
else:
    _mo_map = {'Jan':1,'Feb':2,'Mar':3,'Apr':4,'May':5,'Jun':6,
               'Jul':7,'Aug':8,'Sep':9,'Oct':10,'Nov':11,'Dec':12}

    _snap_keys = sorted(ZA_SNAPSHOT_META.keys())
    _snap_labels = [ZA_SNAPSHOT_META[sk]['label'] for sk in _snap_keys]
    _snap_dates = {
        ZA_SNAPSHOT_META[sk]['label']: ZA_SNAPSHOT_META[sk]['date']
        for sk in _snap_keys
    }

    MIN_DID_N = 20

    # -----------------------------------------------------------------
    # 1. For each wave, find before/after snapshot and compute DID
    # -----------------------------------------------------------------
    _results = []

    for wk in CAMP_MAILER_KEYS:
        _w_yr = int(wk[3:]) + 2000
        _w_mn = _mo_map[wk[:3]]
        _wave_ym = _w_yr * 12 + _w_mn

        # Find before/after snapshots
        _before_label = None
        _after_label = None
        for lbl in _snap_labels:
            _sd = _snap_dates[lbl]
            _s_ym = _sd.year * 12 + _sd.month
            if _s_ym <= _wave_ym:
                _before_label = lbl
            if _s_ym > _wave_ym and _after_label is None:
                _after_label = lbl

        if _before_label is None or _after_label is None:
            continue

        # Check required columns exist
        _amt_before = f"depAmt365_{_before_label}"
        _amt_after = f"depAmt365_{_after_label}"
        _cnt_before = f"depCount365_{_before_label}"
        _cnt_after = f"depCount365_{_after_label}"

        if _amt_before not in _df.columns or _amt_after not in _df.columns:
            continue

        _has_count = (_cnt_before in _df.columns and _cnt_after in _df.columns)

        # Responder / non-responder masks
        _mail_col = CAMP_MAIL_COLS[wk]
        _resp_col = CAMP_RESP_COLS[wk]
        _mailed = _df[_mail_col].notna()
        _responded = _df[_resp_col].map(camp_is_success)
        _resp_mask = _mailed & _responded
        _nonresp_mask = _mailed & ~_responded

        _n_resp = int(_resp_mask.sum())
        _n_nonresp = int(_nonresp_mask.sum())
        if _n_resp < MIN_DID_N or _n_nonresp < MIN_DID_N:
            continue

        # Amount DID
        _amt_valid = _df[_amt_before].notna() & _df[_amt_after].notna()
        _amt_delta = _df[_amt_after] - _df[_amt_before]

        _r_amt = _amt_delta[_resp_mask & _amt_valid]
        _nr_amt = _amt_delta[_nonresp_mask & _amt_valid]

        if len(_r_amt) < MIN_DID_N or len(_nr_amt) < MIN_DID_N:
            continue

        _amt_did = _r_amt.median() - _nr_amt.median()

        # Count DID (frequency confirmation)
        _cnt_did = np.nan
        if _has_count:
            _cnt_valid = _df[_cnt_before].notna() & _df[_cnt_after].notna()
            _cnt_delta = _df[_cnt_after] - _df[_cnt_before]
            _r_cnt = _cnt_delta[_resp_mask & _cnt_valid]
            _nr_cnt = _cnt_delta[_nonresp_mask & _cnt_valid]
            if len(_r_cnt) >= MIN_DID_N and len(_nr_cnt) >= MIN_DID_N:
                _cnt_did = _r_cnt.median() - _nr_cnt.median()

        # Same direction?
        if np.isnan(_cnt_did):
            _same_dir = '-'
        elif (_amt_did >= 0) == (_cnt_did >= 0):
            _same_dir = 'Yes'
        else:
            _same_dir = 'No'

        _results.append({
            'wave': wk,
            'label': f"{wk[:3]} '{wk[3:]}",
            'snapshots': f"{_before_label} -> {_after_label}",
            'n_resp': _n_resp,
            'n_nonresp': _n_nonresp,
            'amt_did': _amt_did,
            'cnt_did': _cnt_did,
            'same_dir': _same_dir,
        })

    # -----------------------------------------------------------------
    # 2. Summary table
    # -----------------------------------------------------------------
    if _results:
        print(f"\n{'=' * 115}")
        print(f"  BUSINESS DEPOSITS -- CAMPAIGN SNAPSHOT DID (Cell 23)")
        print(f"{'=' * 115}")
        print(f"  Amount DID = median(resp depAmt365 delta) - median(nonresp depAmt365 delta)")
        print(f"  Count DID  = same formula on depCount365 (frequency confirmation)")
        print(f"  Same Dir?  = both Amount and Count DID agree on sign")
        print()

        _hdr = (f"  {'Wave':<10s}  {'Snapshots':<22s}  {'N Resp':>7s}  {'N NonResp':>10s}"
                f"  {'Amount DID':>12s}  {'Count DID':>11s}  {'Same Dir?':>10s}")
        print(_hdr)
        print(f"  {'-'*10}  {'-'*22}  {'-'*7}  {'-'*10}  {'-'*12}  {'-'*11}  {'-'*10}")

        _n_same = 0
        _n_comparable = 0
        for r in _results:
            _amt_str = '${:>,.0f}'.format(r['amt_did'])
            if np.isnan(r['cnt_did']):
                _cnt_str = 'N/A'
            else:
                _cnt_str = '{:>,.1f}'.format(r['cnt_did'])
                _n_comparable += 1
                if r['same_dir'] == 'Yes':
                    _n_same += 1

            print(f"  {r['label']:<10s}  {r['snapshots']:<22s}  {r['n_resp']:>7,}"
                  f"  {r['n_nonresp']:>10,}  {_amt_str:>12s}  {_cnt_str:>11s}"
                  f"  {r['same_dir']:>10s}")

        print(f"{'=' * 115}")
        if _n_comparable > 0:
            print(f"\n  Direction agreement: {_n_same}/{_n_comparable} waves "
                  f"({_n_same / _n_comparable * 100:.0f}%)")

        # ---------------------------------------------------------
        # 3. Chart: Amount DID per wave
        # ---------------------------------------------------------
        if len(_results) >= 1:
            fig, ax = plt.subplots(figsize=(max(10, len(_results) * 2.5), 7))
            x = np.arange(len(_results))

            _amt_vals = [r['amt_did'] for r in _results]
            _bar_colors = [
                GEN_COLORS['success'] if v >= 0 else GEN_COLORS['danger']
                for v in _amt_vals
            ]

            bars = ax.bar(x, _amt_vals, 0.6, color=_bar_colors, edgecolor='white')

            for bar, val in zip(bars, _amt_vals):
                ax.text(
                    bar.get_x() + bar.get_width() / 2, bar.get_height(),
                    gen_fmt_dollar(val, None), ha='center',
                    va='bottom' if val >= 0 else 'top',
                    fontsize=12, fontweight='bold',
                )

            ax.axhline(y=0, color=GEN_COLORS['muted'], linewidth=1)
            ax.set_xticks(x)
            ax.set_xticklabels(
                [r['label'] for r in _results],
                fontsize=13, rotation=20, ha='right',
            )
            ax.set_ylabel('Amount DID ($)', fontsize=14, fontweight='bold')
            ax.yaxis.set_major_formatter(mticker.FuncFormatter(gen_fmt_dollar))
            gen_clean_axes(ax)

            fig.suptitle(
                'Business Accounts -- Snapshot DID by Campaign Wave',
                fontsize=22, fontweight='bold',
                color=GEN_COLORS['dark_text'], y=1.02,
            )
            fig.text(
                0.5, -0.02,
                'DID = median(resp depAmt365 delta) - median(nonresp depAmt365 delta)',
                ha='center', fontsize=12, color=GEN_COLORS['muted'],
            )
            plt.tight_layout()
            plt.show()
    else:
        print("    23: No waves had sufficient data for snapshot DID validation")
