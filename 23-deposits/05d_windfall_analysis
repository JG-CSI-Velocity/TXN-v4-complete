    _counts = [_low, _moderate, _high]
    _pcts = [c / _total * 100 for c in _counts]
    _colors = [GEN_COLORS['success'], GEN_COLORS['warning'], GEN_COLORS['accent']]

    fig, axes = plt.subplots(1, 2, figsize=(16, 7))

    # Left: Segment bar chart
    ax = axes[0]
    bars = ax.bar(_segments, _pcts, color=_colors, edgecolor='white', width=0.6)
    for bar, pct, cnt in zip(bars, _pcts, _counts):
        ax.text(bar.get_x() + bar.get_width()/2, bar.get_height(),
