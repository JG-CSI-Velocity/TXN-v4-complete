# DEPOSIT BEHAVIOR: Windfall Dependence Analysis
# ===========================================================================
# What share of accounts rely on windfall deposits (tax refunds, bonuses,
# insurance payouts) vs steady recurring deposits? Uses WindfallRatio from
# ZAccounts -- higher ratio = more windfall-dependent.
#
# Requires: 01_deposit_setup (deposits_df)

import matplotlib.pyplot as plt
import matplotlib.ticker as mticker
import numpy as np

_windfall_field = 'WindfallRatio'
_windfall_trend = 'WindfallTrendCount33'

if _windfall_field not in deposits_df.columns:
    print(f"    WARNING: {_windfall_field} not available -- skipping")
else:
    _wf = pd.to_numeric(deposits_df[_windfall_field], errors='coerce').dropna()

    print(f"    05d Data Decisions:")
    print(f"      Field: {_windfall_field}")
    print(f"      Accounts with data: {len(_wf):,} of {len(deposits_df):,}")
