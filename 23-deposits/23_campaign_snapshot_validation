# ===========================================================================
# PERSONAL DEPOSITS: Campaign-Snapshot Validation
# ===========================================================================
# For each campaign wave, validate the DiD lift (monthly MTD-based) against
# ZAccounts snapshot changes. Does the monthly MTD lift translate into real
# deposit growth at the next snapshot?
#
# MTD-DID: computed from ODDD monthly deposits (pre vs post wave)
# Snapshot-DID: depAmt365 change between before/after snapshots
#
# Cross-source: ODDD (MTD + Mail/Resp cols) + ZAccounts (snapshot depAmt365)
# Data: deposits_personal_df

import matplotlib.pyplot as plt
import matplotlib.ticker as mticker
import numpy as np

_df = deposits_personal_df.copy()

if not HAS_CAMPAIGN_DATA:
    print("    23 Skipped: no campaign data")
elif not ZA_HAS_MULTIPLE:
    print("    23 Skipped: requires 2+ ZAccounts snapshots")
elif not mtd_cols:
    print("    23 Skipped: no MTD columns")
else:
    _mo_map = {'Jan':1,'Feb':2,'Mar':3,'Apr':4,'May':5,'Jun':6,
               'Jul':7,'Aug':8,'Sep':9,'Oct':10,'Nov':11,'Dec':12}
    _all_mtd_keys = sorted(mtd_cols.keys(), key=_camp_month_sort_key)
    _snap_keys = sorted(ZA_SNAPSHOT_META.keys())
    _snap_labels = [ZA_SNAPSHOT_META[sk]['label'] for sk in _snap_keys]
    _snap_dates = {ZA_SNAPSHOT_META[sk]['label']: ZA_SNAPSHOT_META[sk]['date'] for sk in _snap_keys}

    _MIN_DID_N = 20

    # -----------------------------------------------------------------
    # 1. Map each wave to before/after snapshot pair
    # -----------------------------------------------------------------
    def _wave_to_ym(wk):
        return (int(wk[3:]) + 2000, _mo_map.get(wk[:3], 1))

    _results = []
    for wk in CAMP_MAILER_KEYS:
        _w_yr, _w_mn = _wave_to_ym(wk)
        _wave_date = _w_yr * 12 + _w_mn

        # Find before/after snapshots
        _before_label = None
        _after_label = None
        for lbl in _snap_labels:
            _sd = _snap_dates[lbl]
            _s_date = _sd.year * 12 + _sd.month
            if _s_date <= _wave_date:
                _before_label = lbl
            if _s_date > _wave_date and _after_label is None:
                _after_label = lbl

        # Need both for snapshot DID
        _has_snapshot_pair = (_before_label is not None and _after_label is not None)

        # Compute MTD-based DID (same pattern as 14g)
        _pre_months = []
        _post_months = []
        for mk in _all_mtd_keys:
            _m_yr = int(mk[3:]) + 2000
            _m_mn = _mo_map.get(mk[:3], 1)
            _diff = (_w_yr - _m_yr) * 12 + (_w_mn - _m_mn)
            if 1 <= _diff <= 3:
                _pre_months.append(mk)
            _diff_post = (_m_yr - _w_yr) * 12 + (_m_mn - _w_mn)
            if 1 <= _diff_post <= 3:
                _post_months.append(mk)

        if len(_pre_months) < 2 or not _post_months:
            continue

        _mail_col = CAMP_MAIL_COLS[wk]
        _resp_col = CAMP_RESP_COLS[wk]
        _mailed = _df[_mail_col].notna()
        _responded = _df[_resp_col].map(camp_is_success)
        _resp_mask = _mailed & _responded
        _nonresp_mask = _mailed & ~_responded

        _n_resp = int(_resp_mask.sum())
        _n_nonresp = int(_nonresp_mask.sum())
        if _n_resp < _MIN_DID_N or _n_nonresp < _MIN_DID_N:
            continue

        # MTD DID
        _pre_cols = [mtd_cols[m] for m in _pre_months if m in mtd_cols]
        _post_cols = [mtd_cols[m] for m in _post_months if m in mtd_cols]
        _pre_valid = _df[_pre_cols].notna().sum(axis=1) >= 2
        _pre_mean = _df[_pre_cols].mean(axis=1)
        _post_mean = _df[_post_cols].mean(axis=1)
        _delta = _post_mean - _pre_mean

        _resp_delta_mtd = _delta[_resp_mask & _pre_valid].median()
        _nonresp_delta_mtd = _delta[_nonresp_mask & _pre_valid].median()
        _mtd_did = _resp_delta_mtd - _nonresp_delta_mtd

        # Snapshot DID (if pair available)
        _snap_did = np.nan
        _snap_note = 'no post snapshot'
        if _has_snapshot_pair:
            _before_col = f"depAmt365_{_before_label}"
            _after_col = f"depAmt365_{_after_label}"
            if _before_col in _df.columns and _after_col in _df.columns:
                _both_valid = _df[_before_col].notna() & _df[_after_col].notna()
                _snap_delta = _df[_after_col] - _df[_before_col]
                _r_snap = _snap_delta[_resp_mask & _both_valid]
                _nr_snap = _snap_delta[_nonresp_mask & _both_valid]
                if len(_r_snap) >= _MIN_DID_N and len(_nr_snap) >= _MIN_DID_N:
                    _snap_did = _r_snap.median() - _nr_snap.median()
                    # Agreement: do both methods show same sign?
                    if not np.isnan(_snap_did):
                        _agree = 'Yes' if (_mtd_did >= 0) == (_snap_did >= 0) else 'No'
                        _snap_note = f"{_before_label}->{_after_label}, agree={_agree}"
                    else:
                        _snap_note = 'insufficient data'

        _results.append({
            'wave': wk,
            'label': f"{wk[:3]} '{wk[3:]}",
            'n_resp': _n_resp,
            'n_nonresp': _n_nonresp,
            'mtd_did': _mtd_did,
            'snap_did': _snap_did,
            'snap_note': _snap_note,
            'before': _before_label,
            'after': _after_label,
        })

    # -----------------------------------------------------------------
    # 2. Conference table
    # -----------------------------------------------------------------
    if _results:
        print(f"\n{'=' * 110}")
        print(f"  PERSONAL DEPOSITS — CAMPAIGN-SNAPSHOT VALIDATION (Cell 23)")
        print(f"{'=' * 110}")
        print(f"  MTD DID: monthly ODDD deposits (3-month pre/post windows)")
        print(f"  Snapshot DID: depAmt365 change between before/after snapshots")
        print(f"  Agreement: both methods show same direction of lift")
        print()

        _hdr = (f"  {'Wave':<10s}  {'Resp':>7s}  {'NonResp':>8s}"
                f"  {'MTD DID':>12s}  {'Snap DID':>14s}  {'Agree':>6s}  {'Snapshots':<20s}")
        print(_hdr)
        print(f"  {'-'*10}  {'-'*7}  {'-'*8}  {'-'*12}  {'-'*14}  {'-'*6}  {'-'*20}")

        _n_agree = 0
        _n_comparable = 0
        for r in _results:
            _mtd_str = '${:>,.0f}'.format(r['mtd_did'])
            if np.isnan(r['snap_did']):
                _snap_str = 'N/A'
                _agree_str = '-'
            else:
                _snap_str = '${:>,.0f}'.format(r['snap_did'])
                _agree_str = 'Yes' if (r['mtd_did'] >= 0) == (r['snap_did'] >= 0) else 'No'
                _n_comparable += 1
                if _agree_str == 'Yes':
                    _n_agree += 1

            _snap_pair = f"{r['before'] or '?'} -> {r['after'] or '?'}"
            print(f"  {r['label']:<10s}  {r['n_resp']:>7,}  {r['n_nonresp']:>8,}"
                  f"  {_mtd_str:>12s}  {_snap_str:>14s}  {_agree_str:>6s}  {_snap_pair:<20s}")

        print(f"{'=' * 110}")
        if _n_comparable > 0:
            print(f"\n  Agreement rate: {_n_agree}/{_n_comparable} waves "
                  f"({_n_agree / _n_comparable * 100:.0f}%)")

        # ---------------------------------------------------------
        # 3. Chart: paired bar per wave
        # ---------------------------------------------------------
        _chart_results = [r for r in _results if not np.isnan(r['snap_did'])]
        if len(_chart_results) >= 2:
            fig, ax = plt.subplots(figsize=(max(14, len(_chart_results) * 3), 7))
            x = np.arange(len(_chart_results))
            _w = 0.35

            _mtd_vals = [r['mtd_did'] for r in _chart_results]
            _snap_vals = [r['snap_did'] for r in _chart_results]

            bars1 = ax.bar(x - _w/2, _mtd_vals, _w, label='MTD DID ($/month)',
                           color=GEN_COLORS['primary'], edgecolor='white')
            bars2 = ax.bar(x + _w/2, _snap_vals, _w, label='Snapshot DID ($/year)',
                           color=GEN_COLORS['success'], edgecolor='white')

            for bar, val in zip(bars1, _mtd_vals):
                ax.text(bar.get_x() + bar.get_width() / 2, bar.get_height(),
                        gen_fmt_dollar(val, None), ha='center',
                        va='bottom' if val >= 0 else 'top',
                        fontsize=11, fontweight='bold')
            for bar, val in zip(bars2, _snap_vals):
                ax.text(bar.get_x() + bar.get_width() / 2, bar.get_height(),
                        gen_fmt_dollar(val, None), ha='center',
                        va='bottom' if val >= 0 else 'top',
                        fontsize=11, fontweight='bold')

            ax.axhline(y=0, color=GEN_COLORS['muted'], linewidth=1)
            ax.set_xticks(x)
            ax.set_xticklabels([r['label'] for r in _chart_results],
                               fontsize=13, rotation=20, ha='right')
            ax.set_ylabel('DID Lift ($)', fontsize=14, fontweight='bold')
            ax.yaxis.set_major_formatter(mticker.FuncFormatter(gen_fmt_dollar))
            ax.legend(fontsize=12, frameon=False)
            gen_clean_axes(ax)

            fig.suptitle('Personal Accounts \u2014 Campaign DID: Monthly vs Snapshot Validation',
                         fontsize=22, fontweight='bold', color=GEN_COLORS['dark_text'], y=1.02)
            fig.text(0.5, -0.02,
                     f'MTD = 3-month ODDD windows  |  Snapshot = depAmt365 between ZAccounts snapshots',
                     ha='center', fontsize=12, color=GEN_COLORS['muted'])
            plt.tight_layout()
            plt.show()
        elif _chart_results:
            print("    Only 1 wave with snapshot validation — chart requires 2+")
    else:
        print("    23: No waves had sufficient data for validation")
