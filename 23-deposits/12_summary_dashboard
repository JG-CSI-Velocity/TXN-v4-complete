    _sw = pd.to_numeric(deposits_df[_swipe_col_sum], errors='coerce')
    _dc = pd.to_numeric(deposits_df['depCount365'], errors='coerce')
    _valid = _sw.notna() & _dc.notna()
    if _valid.sum() > 10:
        _corr_val = _sw[_valid].corr(_dc[_valid])

# Spend-to-deposit ratio (latest 3 months)
