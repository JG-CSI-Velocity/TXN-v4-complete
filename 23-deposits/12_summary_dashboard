    _pie_colors = [DEPOSIT_TIER_PALETTE.get(t, GEN_COLORS['muted']) for t in _pie_labels]

    wedges, texts, autotexts = ax1.pie(
        _pie_vals, labels=_pie_labels, colors=_pie_colors,
        autopct='%1.0f%%', startangle=90, textprops={'fontsize': 14}
    )
    for autotext in autotexts:
        autotext.set_fontweight('bold')
        autotext.set_fontsize(14)
    ax1.set_title('Deposit Health Distribution',
                  fontsize=16, fontweight='bold', color=GEN_COLORS['dark_text'])

    # Swipe category vs deposit count (if available)
    _swipecat_col = None
    for candidate in ['SwipeCat12', 'SwipeCat3']:
        if candidate in deposits_df.columns:
            _swipecat_col = candidate
            break

    if _swipecat_col and _has_dep365:
        _cat_dep = (
            deposits_df.groupby(_swipecat_col)
            .apply(
                lambda g: pd.to_numeric(g['depCount365'], errors='coerce').mean(),
                include_groups=False
            )
            .sort_values(ascending=True)
        )

        ax2.barh(_cat_dep.index.astype(str), _cat_dep.values,
                 color=GEN_COLORS['info'], edgecolor='white', height=0.6)
        ax2.set_title(f'Avg Deposits by {_swipecat_col}',
                      fontsize=16, fontweight='bold', color=GEN_COLORS['dark_text'])
        ax2.set_xlabel('Avg Deposit Count (365d)', fontsize=14)
        ax2.tick_params(labelsize=12)
        ax2.spines[['top', 'right']].set_visible(False)
        for i, val in enumerate(_cat_dep.values):
            ax2.text(val, i, f' {val:.1f}', va='center',
                     fontsize=12, fontweight='bold')
    else:
        ax2.axis('off')
        ax2.text(0.5, 0.5, 'Swipe category data\nnot available',
                 ha='center', va='center', fontsize=14,
                 color=GEN_COLORS['muted'], transform=ax2.transAxes)

    plt.tight_layout()
    plt.show()

