        _img = _save_fig(fig, 'nu_deposits')
        _add_image_slide("NU Conversion: Deposits by Activation Level", _img)

    # =================================================================
    # SLIDE 9: Sustained engagement table
    # =================================================================
    if 'mo_swipes_3mo' in _acct.columns:
        _persist_rows = []
        for seg in PROGRAM_SEG_ORDER:
            _sm = _acct['program_segment'] == seg
            for label, mask in [('R', _sm & _r_mask), ('NR', _sm & _nr_mask)]:
                _g = _acct[mask]
                if len(_g) < 10:
                    continue
                _s3 = _g['mo_swipes_3mo'].median()
                _s12 = _g['mo_swipes_12mo'].median()
                _trend = f'{_s3 / _s12:.2f}x' if _s12 > 0 else '--'
                _persist_rows.append({
                    'Group': f'{seg} {label}',
                    '12mo Avg': f'{_s12:.1f}',
                    'Recent 3mo': f'{_s3:.1f}',
                    'Trend': _trend,
                })
        if _persist_rows:
            _add_table_slide("Sustained Engagement: 3mo vs 12mo Swipes",
                              pd.DataFrame(_persist_rows))

    # =================================================================
    # SLIDE 10: Deposit context
    # =================================================================
    if 'mo_dep_amt' in _acct.columns:
        _r_dep = _acct.loc[_r_mask, 'mo_dep_amt'].median()
        _nr_dep = _acct.loc[_nr_mask, 'mo_dep_amt'].median()
        _r_spend = _acct.loc[_r_mask, 'mo_spend_12mo'].median()
        _nr_spend = _acct.loc[_nr_mask, 'mo_spend_12mo'].median()
        _lift = _r_spend - _nr_spend
        _interchange = _lift * 0.015

        _dep_ctx = pd.DataFrame([
            {'': 'Monthly Deposits', 'Responder': f'${_r_dep:,.0f}',
             'Non-Responder': f'${_nr_dep:,.0f}', 'Insight': 'Comparable'},
            {'': 'Monthly Card Spend', 'Responder': f'${_r_spend:,.0f}',
             'Non-Responder': f'${_nr_spend:,.0f}', 'Insight': 'R spends more'},
            {'': 'Spend/Deposit Ratio',
             'Responder': f'{_r_spend / _r_dep:.1%}' if _r_dep > 0 else '--',
             'Non-Responder': f'{_nr_spend / _nr_dep:.1%}' if _nr_dep > 0 else '--',
             'Insight': 'Higher utilization'},
            {'': 'Interchange Lift',
             'Responder': f'${_interchange:,.2f}/acct/mo',
             'Non-Responder': '--',
             'Insight': f'x {_n_resp:,} = ${_interchange * _n_resp:,.0f}/mo'},
        ])
        _add_table_slide("Same Deposits, More Card Revenue", _dep_ctx)

    # =================================================================
    # Save
    # =================================================================
    prs.save(str(_OUTPUT_FILE))
    print(f"\n  PowerPoint saved: {_OUTPUT_FILE}")
    print(f"  Slides: {len(prs.slides)}")

    # Cleanup temp images
    import shutil
    shutil.rmtree(_tmpdir, ignore_errors=True)
