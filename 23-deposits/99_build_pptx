        gen_clean_axes(ax)
        ax.yaxis.grid(True, color=GEN_COLORS['grid'], linewidth=0.5, alpha=0.7)
        ax.set_axisbelow(True)
        ax.set_title("Card Activation Drives Deposits", fontsize=22,
                      fontweight='bold', color=GEN_COLORS['dark_text'], pad=15)
