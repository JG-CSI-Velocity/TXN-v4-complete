                    x = np.arange(len(_bar_vals))
                    bars = ax2.bar(x, _bar_vals, color=_bar_colors, edgecolor='white', width=0.6)
                    for bar, val in zip(bars, _bar_vals):
                        if val > 0:
                            ax2.text(bar.get_x() + bar.get_width() / 2, bar.get_height(),
                                     gen_fmt_dollar(val, None), ha='center', va='bottom',
                                     fontsize=12, fontweight='bold')
                    ax2.set_xticks(x)
                    ax2.set_xticklabels(_bar_labels, fontsize=11)
                    ax2.set_ylabel(f'Median {_chart_label}', fontsize=14, fontweight='bold')
                    ax2.yaxis.set_major_formatter(mticker.FuncFormatter(gen_fmt_dollar))
                    gen_clean_axes(ax2)

                    fig.suptitle('Personal Accounts \u2014 OD Recovery & Deposit Patterns',
                                 fontsize=22, fontweight='bold', color=GEN_COLORS['dark_text'], y=1.02)
                    fig.text(0.5, -0.02,
                             f'{_n_od_accts:,} accounts with OD events  |  Source: ZTrends + ZAccounts',
                             ha='center', fontsize=12, color=GEN_COLORS['muted'])
                    plt.tight_layout()
                    plt.show()
                else:
                    print("    Not enough recovery categories for chart")
