# ===========================================================================
# TH TIER BALANCE TRAJECTORY: Matched Cohort Across Snapshots (Conference Ed.)
# ===========================================================================
# Line chart: matched cohort balance across snapshots, 4 lines for TH tiers.
# Solid = mean, dashed = median (same pattern as cell 24_balance_trajectory).
#
# Depends on: deposit_long (23/01), RESPONSE_TIER_PALETTE (23/02),
#             SNAPSHOT_CONFIG, SNAPSHOT_ORDER, GEN_COLORS

if 'deposit_long' not in dir() or len(deposit_long) == 0:
    print("    No longitudinal deposit data. Run cells 01-02 first.")
elif 'in_matched_cohort' not in deposit_long.columns:
    print("    No in_matched_cohort flag. Run cell 01 first.")
elif deposit_long['snapshot'].nunique() < 2:
    print("    Need at least 2 snapshots for trajectory analysis.")
else:
    _th_tiers = ['TH-10', 'TH-15', 'TH-20', 'TH-25']
    _cohort = deposit_long[
        (deposit_long['in_matched_cohort']) &
        (deposit_long['best_tier'].str.startswith('TH-', na=False))
    ].copy()

    if len(_cohort) == 0:
        print("    No matched cohort accounts with TH-* best_tier.")
    else:
        _snap_order = [s for s in SNAPSHOT_ORDER if s in _cohort['snapshot'].unique()]
        _snap_labels = [SNAPSHOT_CONFIG[s]['label'] for s in _snap_order]
        _n_cohort = _cohort['HASHED_ACCOUNT'].nunique()

        fig, ax = plt.subplots(figsize=(14, 7))

        for tier in _th_tiers:
            _tier_data = _cohort[_cohort['best_tier'] == tier]
            if _tier_data['HASHED_ACCOUNT'].nunique() == 0:
                continue

            _means = []
            _medians = []
            for snap in _snap_order:
                _snap_data = _tier_data[_tier_data['snapshot'] == snap]['balance']
                _means.append(_snap_data.mean() if len(_snap_data) > 0 else np.nan)
                _medians.append(_snap_data.median() if len(_snap_data) > 0 else np.nan)

            _color = RESPONSE_TIER_PALETTE.get(tier, GEN_COLORS['muted'])
            _n = _tier_data['HASHED_ACCOUNT'].nunique()

            # Mean line (solid)
            ax.plot(range(len(_snap_order)), _means,
                    color=_color, linewidth=3, marker='o', markersize=10,
                    markeredgecolor='white', markeredgewidth=2,
                    label=f"{tier} mean ({_n:,})", zorder=5)

            # Median line (dashed)
            ax.plot(range(len(_snap_order)), _medians,
                    color=_color, linewidth=2, marker='s', markersize=7,
                    markeredgecolor='white', markeredgewidth=1.5,
                    linestyle='--', alpha=0.7,
                    label=f"{tier} median", zorder=4)

            # Label last point (mean)
            if not np.isnan(_means[-1]):
                ax.text(len(_snap_order) - 1 + 0.12, _means[-1],
                        f"{gen_fmt_dollar(_means[-1], None)}",
                        fontsize=11, fontweight='bold', va='center', color=_color)

        ax.set_xticks(range(len(_snap_order)))
        ax.set_xticklabels(_snap_labels, fontsize=16, fontweight='bold')
        ax.set_ylabel("Balance", fontsize=16, fontweight='bold', labelpad=10)
        ax.yaxis.set_major_formatter(mticker.FuncFormatter(gen_fmt_dollar))

        gen_clean_axes(ax)
        ax.yaxis.grid(True, color=GEN_COLORS['grid'], linewidth=0.5, alpha=0.7)
        ax.set_axisbelow(True)
        ax.legend(fontsize=11, loc='upper left', frameon=True, ncol=2,
                  facecolor='white', edgecolor=GEN_COLORS['grid'])

        ax.set_title("TH Tier Balance Trajectory (Matched Cohort)",
                      fontsize=26, fontweight='bold',
                      color=GEN_COLORS['dark_text'], pad=35, loc='left')
        ax.text(0.0, 1.02,
                f"Which threshold tiers grow deposits over time?  |  "
                f"Matched cohort: {_n_cohort:,} accts  |  Solid = mean, dashed = median",
                transform=ax.transAxes, fontsize=14,
                color=GEN_COLORS['muted'], style='italic')

        plt.tight_layout()
        plt.show()
