# ===========================================================================
# DEPOSIT BALANCE CHANGE: Per-Mailer Grouped Bar (Conference Edition)
# ===========================================================================
# One chart per mailer: grouped bars showing avg deposit balance CHANGE
# (after snapshot - before snapshot) for Responder vs Non-Responder,
# per segment. Never Mailed delta as reference line.
#
# Depends on: wave_cohort_df (23/11), rewards_df, deposit_long,
#             SEGMENT_ORDER, SNAPSHOT_ORDER, SNAPSHOT_CONFIG, GEN_COLORS

if 'wave_cohort_df' not in dir() or len(wave_cohort_df) == 0:
    print("    No cohort data. Run cell 11 first.")
elif 'delta_balance' not in wave_cohort_df.columns:
    print("    No deposit deltas. Mailers may lack before+after snapshot pairing.")
else:
    from IPython.display import display

    _cohort = wave_cohort_df.rename(columns={'wave': 'mailer'})

    # -----------------------------------------------------------------
    # Never Mailed control delta
    # -----------------------------------------------------------------
    _nm_delta = np.nan
    _nm_n = 0

    if ('rewards_df' in dir() and 'deposit_long' in dir()
            and len(deposit_long) > 0):
        _acct_col = ('Acct Number' if 'Acct Number' in rewards_df.columns
                      else ' Acct Number')
        _acct_nums = rewards_df[_acct_col].astype(str).str.strip()
        _mailed_accts = set(_cohort['acct_number'].unique())
        _never_mailed = set(_acct_nums) - _mailed_accts
        _nm_n = len(_never_mailed)

        _dep_join = (DEPOSIT_JOIN_KEY_ODDD
                     if 'DEPOSIT_JOIN_KEY_ODDD' in dir() else None)
        _dep_key_col = (DEPOSIT_JOIN_KEY_DEPOSIT
                        if 'DEPOSIT_JOIN_KEY_DEPOSIT' in dir() else None)

        if (_dep_join and _dep_join in rewards_df.columns and _dep_key_col):
            _nm_mask = _acct_nums.isin(_never_mailed)
            _nm_keys = set(
                rewards_df.loc[_nm_mask, _dep_join].astype(str).str.strip())

            _snap_dates_local = {}
            if 'SNAPSHOT_CONFIG' in dir():
                for sk in SNAPSHOT_ORDER:
                    cfg = SNAPSHOT_CONFIG[sk]
                    try:
                        _snap_dates_local[sk] = pd.to_datetime(
                            cfg['label'], format='%b %Y')
                    except (ValueError, KeyError):
                        if 'sort_key' in cfg:
                            _snap_dates_local[sk] = pd.Timestamp(
                                year=cfg['sort_key'] // 100,
                                month=cfg['sort_key'] % 100, day=1)

            _nm_snap_bals = {}
            if _dep_key_col in deposit_long.columns:
                for sk in SNAPSHOT_ORDER:
                    _snap = deposit_long[deposit_long['snapshot'] == sk]
                    if 'balance' not in _snap.columns:
                        continue
                    _sk = _snap[_dep_key_col].astype(str).str.strip()
                    _matched = _snap[_sk.isin(_nm_keys)]
                    if len(_matched) > 0:
                        _nm_snap_bals[sk] = _matched['balance'].mean()

            _sorted_snaps = sorted(
                _nm_snap_bals.keys(),
                key=lambda k: _snap_dates_local.get(k, pd.Timestamp.min))
            if len(_sorted_snaps) >= 2:
                _nm_delta = (_nm_snap_bals[_sorted_snaps[-1]]
                             - _nm_snap_bals[_sorted_snaps[0]])

        print(f"  Never Mailed control: {_nm_n:,} accounts, "
              f"delta={'${:+,.0f}'.format(_nm_delta) if pd.notna(_nm_delta) else 'n/a'}")

    # -----------------------------------------------------------------
    # Filter to mailers with before+after snapshot data
    # -----------------------------------------------------------------
    _valid = _cohort[
        _cohort['before_snap'].notna() & _cohort['after_snap'].notna()
        & _cohort['delta_balance'].notna()
    ].copy()

    if len(_valid) == 0:
        print("    No mailers with before+after deposit data.")
    else:
        _mailers = sorted(_valid['mailer'].unique(),
                           key=lambda m: pd.to_datetime(m, format='%b%y'))

        # ---------------------------------------------------------------
        # One grouped bar chart per mailer
        # ---------------------------------------------------------------
        _did_rows = []

        for mailer in _mailers:
            _mdf = _valid[_valid['mailer'] == mailer]
            _before = _mdf['before_snap'].iloc[0]
            _after = _mdf['after_snap'].iloc[0]

            _segs = [s for s in SEGMENT_ORDER if s in _mdf['segment'].values]
            if len(_segs) == 0:
                continue

            fig, ax = plt.subplots(figsize=(14, 7))
            _x = np.arange(len(_segs))
            _w = 0.35

            _r_vals, _nr_vals = [], []
            _r_ns, _nr_ns = [], []

            for seg in _segs:
                _seg_data = _mdf[_mdf['segment'] == seg]
                _r = _seg_data[_seg_data['outcome'] == 'Responder']['delta_balance']
                _nr = _seg_data[_seg_data['outcome'] == 'Non-Responder']['delta_balance']
                _r_vals.append(_r.mean() if len(_r) > 0 else 0)
                _nr_vals.append(_nr.mean() if len(_nr) > 0 else 0)
                _r_ns.append(len(_r))
                _nr_ns.append(len(_nr))

                # Collect for DID table
                _r_d = _r.mean() if len(_r) > 0 else np.nan
                _nr_d = _nr.mean() if len(_nr) > 0 else np.nan
                _did = (_r_d - _nr_d
                        if pd.notna(_r_d) and pd.notna(_nr_d) else np.nan)
                _did_rows.append({
                    'Segment': seg, 'Mailer': mailer,
                    'Resp N': len(_r), 'Resp Delta': _r_d,
                    'NR N': len(_nr), 'NR Delta': _nr_d,
                    'NM Delta': _nm_delta, 'DID Lift': _did,
                })

            ax.bar(_x - _w / 2, _r_vals, _w,
                   color=GEN_COLORS['success'], edgecolor='white',
                   linewidth=1.5, label='Responded', zorder=3)
            ax.bar(_x + _w / 2, _nr_vals, _w,
                   color=GEN_COLORS['muted'], edgecolor='white',
                   linewidth=1.5, label='Did Not Respond', zorder=3)

            # Never Mailed reference line
            if pd.notna(_nm_delta):
                ax.axhline(y=_nm_delta, color=GEN_COLORS['warning'],
                           linewidth=2, linestyle='--', alpha=0.8,
                           label=f'Never Mailed ({_nm_n:,}): '
                                 f'{"+"if _nm_delta >= 0 else ""}${_nm_delta:,.0f}',
                           zorder=2)

            # Annotations
            _all_vals = [v for v in _r_vals + _nr_vals if v != 0]
            _max_abs = max(abs(v) for v in _all_vals) if _all_vals else 1

            for j in range(len(_segs)):
                for val, offset, n in [(_r_vals[j], -_w/2, _r_ns[j]),
                                        (_nr_vals[j], _w/2, _nr_ns[j])]:
                    _sign = '+' if val >= 0 else ''
                    _va = 'bottom' if val >= 0 else 'top'
                    _y = val + (_max_abs * 0.04 if val >= 0
                                else -_max_abs * 0.04)
                    ax.text(j + offset, _y,
                            f"{_sign}${val:,.0f}\n(n={n:,})",
                            ha='center', va=_va, fontsize=10,
                            fontweight='bold',
                            color=GEN_COLORS['dark_text'],
                            linespacing=1.2)

            ax.axhline(y=0, color=GEN_COLORS['dark_text'],
                        linewidth=0.8, alpha=0.5)
            ax.set_xticks(_x)
            ax.set_xticklabels(_segs, fontsize=14, fontweight='bold')
            ax.set_ylabel("Avg Balance Change ($)", fontsize=16,
                           fontweight='bold', labelpad=10)
            ax.yaxis.set_major_formatter(mticker.FuncFormatter(gen_fmt_dollar))

            gen_clean_axes(ax)
            ax.yaxis.grid(True, color=GEN_COLORS['grid'],
                           linewidth=0.5, alpha=0.7)
            ax.set_axisbelow(True)
            ax.legend(fontsize=12, loc='upper right', frameon=True,
                      facecolor='white', edgecolor=GEN_COLORS['grid'])

            _b_label = (SNAPSHOT_CONFIG[_before]['label']
                        if 'SNAPSHOT_CONFIG' in dir() and _before in SNAPSHOT_CONFIG
                        else _before)
            _a_label = (SNAPSHOT_CONFIG[_after]['label']
                        if 'SNAPSHOT_CONFIG' in dir() and _after in SNAPSHOT_CONFIG
                        else _after)

            ax.set_title(f"{mailer} Mailer: Deposit Balance Change by Segment",
                          fontsize=24, fontweight='bold',
                          color=GEN_COLORS['dark_text'], pad=35, loc='left')
            ax.text(0.0, 1.02,
                    f"Before: {_b_label}  |  After: {_a_label}  |  "
                    f"{len(_mdf):,} accounts  |  "
                    f"Amber dashed = never mailed control",
                    transform=ax.transAxes, fontsize=12,
                    color=GEN_COLORS['muted'], style='italic')

            plt.tight_layout()
            plt.show()

        # ---------------------------------------------------------------
        # ALL MAILERS aggregate rows for table
        # ---------------------------------------------------------------
        for seg in SEGMENT_ORDER:
            _s = _valid[_valid['segment'] == seg]
            _r = _s[_s['outcome'] == 'Responder']
            _nr = _s[_s['outcome'] == 'Non-Responder']
            if len(_r) == 0 and len(_nr) == 0:
                continue
            _r_d = _r['delta_balance'].mean() if len(_r) > 0 else np.nan
            _nr_d = _nr['delta_balance'].mean() if len(_nr) > 0 else np.nan
            _did = (_r_d - _nr_d
                    if pd.notna(_r_d) and pd.notna(_nr_d) else np.nan)
            _did_rows.insert(0, {
                'Segment': seg, 'Mailer': 'ALL MAILERS',
                'Resp N': len(_r), 'Resp Delta': _r_d,
                'NR N': len(_nr), 'NR Delta': _nr_d,
                'NM Delta': _nm_delta, 'DID Lift': _did,
            })

        # ---------------------------------------------------------------
        # Styled DID table
        # ---------------------------------------------------------------
        _did_df = pd.DataFrame(_did_rows)
        _disp_cols = ['Segment', 'Mailer', 'Resp N', 'Resp Delta',
                      'NR N', 'NR Delta', 'NM Delta', 'DID Lift']
        _disp_cols = [c for c in _disp_cols if c in _did_df.columns]
        _display_df = _did_df[_disp_cols].copy()

        _seg_breaks = set()
        _prev = None
        for i, row in _display_df.iterrows():
            if row['Segment'] != _prev and _prev is not None:
                _seg_breaks.add(i)
            _prev = row['Segment']

        _agg_idx = set(
            _display_df[_display_df['Mailer'] == 'ALL MAILERS'].index)

        def _style_rows(row):
            parts = []
            if row.name in _agg_idx:
                parts += ['font-weight: bold',
                          'background-color: rgba(27, 42, 74, 0.05)']
            if row.name in _seg_breaks:
                parts.append('border-top: 2px solid #1B2A4A')
            css = '; '.join(parts) if parts else ''
            return [css] * len(row)

        def _color_deltas(col):
            if col.name not in ('DID Lift', 'Resp Delta', 'NR Delta', 'NM Delta'):
                return [''] * len(col)
            return [
                f'color: {GEN_COLORS["success"]}' if pd.notna(v) and v > 0
                else f'color: {GEN_COLORS["accent"]}' if pd.notna(v) and v < 0
                else ''
                for v in col
            ]

        def _fmt_d(v):
            if pd.isna(v): return '--'
            return f"{'+'if v >= 0 else '-'}${abs(v):,.0f}"

        _styled = (
            _display_df.style
            .hide(axis='index')
            .format({
                'Resp N': '{:,.0f}', 'NR N': '{:,.0f}',
                'Resp Delta': _fmt_d, 'NR Delta': _fmt_d,
                'NM Delta': _fmt_d, 'DID Lift': _fmt_d,
            }, na_rep='--')
            .apply(_style_rows, axis=1)
            .apply(_color_deltas)
            .set_properties(**{
                'font-size': '13px', 'text-align': 'center',
                'border': '1px solid #E9ECEF', 'padding': '8px 10px',
            })
            .set_properties(subset=['Segment'], **{
                'font-weight': 'bold', 'text-align': 'left',
                'color': GEN_COLORS['primary'],
            })
            .set_properties(subset=['Mailer'], **{'text-align': 'left'})
            .set_table_styles([
                {'selector': 'th', 'props': [
                    ('background-color', GEN_COLORS['primary']),
                    ('color', 'white'), ('font-size', '13px'),
                    ('font-weight', 'bold'), ('text-align', 'center'),
                    ('padding', '8px 10px'),
                ]},
                {'selector': 'caption', 'props': [
                    ('font-size', '22px'), ('font-weight', 'bold'),
                    ('color', GEN_COLORS['dark_text']),
                    ('text-align', 'left'), ('padding-bottom', '12px'),
                ]},
            ])
            .set_caption("Deposit Balance Change: Resp vs NR by Segment x Mailer")
        )
        display(_styled)

        # Narrative
        _agg = [r for r in _did_rows if r['Mailer'] == 'ALL MAILERS']
        if _agg:
            print(f"\n  Deposit DID (all mailers pooled):")
            _pos = 0
            for row in _agg:
                _d = row.get('DID Lift')
                if pd.notna(_d):
                    print(f"    {row['Segment']:<8s}: "
                          f"{'+'if _d >= 0 else '-'}${abs(_d):,.0f}  "
                          f"({'DEPOSITS UP' if _d > 0 else 'FLAT/DOWN'})")
                    _pos += _d > 0
            print(f"\n    {_pos}/{len(_agg)} segments show positive "
                  f"deposit lift from responding")
