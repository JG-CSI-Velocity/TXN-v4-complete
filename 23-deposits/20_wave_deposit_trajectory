# ===========================================================================
# DEPOSIT TRAJECTORY: Balance at Each Snapshot, Per Mailer (Conf. Ed.)
# ===========================================================================
# One full-size chart per mailer showing actual deposit BALANCES at
# each snapshot. Lines by segment (Resp solid, NR dashed). Never Mailed
# as flat baseline. Styled DID table below for segment detail.
#
# Depends on: wave_cohort_df (23/11), rewards_df, deposit_long,
#             SEGMENT_ORDER, SNAPSHOT_ORDER, SNAPSHOT_CONFIG, GEN_COLORS

if 'wave_cohort_df' not in dir() or len(wave_cohort_df) == 0:
    print("    No cohort data. Run cell 11 first.")
else:
    from IPython.display import display

    _cohort = wave_cohort_df.rename(columns={'wave': 'mailer'})

    # -----------------------------------------------------------------
    # Never Mailed control: balance at each snapshot
    # -----------------------------------------------------------------
    _nm_snap_balances = {}
    _nm_n = 0

    if ('rewards_df' in dir() and 'deposit_long' in dir()
            and len(deposit_long) > 0):
        _acct_col = ('Acct Number' if 'Acct Number' in rewards_df.columns
                      else ' Acct Number')
        _acct_nums = rewards_df[_acct_col].astype(str).str.strip()
        _mailed_accts = set(_cohort['acct_number'].unique())
        _never_mailed = set(_acct_nums) - _mailed_accts
        _nm_n = len(_never_mailed)

        _dep_join = (DEPOSIT_JOIN_KEY_ODDD
                     if 'DEPOSIT_JOIN_KEY_ODDD' in dir() else None)
        _dep_key_col = (DEPOSIT_JOIN_KEY_DEPOSIT
                        if 'DEPOSIT_JOIN_KEY_DEPOSIT' in dir() else None)

        if (_dep_join and _dep_join in rewards_df.columns and _dep_key_col):
            _nm_mask = _acct_nums.isin(_never_mailed)
            _nm_keys = set(
                rewards_df.loc[_nm_mask, _dep_join].astype(str).str.strip())
            if _dep_key_col in deposit_long.columns:
                for sk in SNAPSHOT_ORDER:
                    _snap = deposit_long[deposit_long['snapshot'] == sk]
                    if 'balance' not in _snap.columns:
                        continue
                    _snap_keys = _snap[_dep_key_col].astype(str).str.strip()
                    _nm_matched = _snap[_snap_keys.isin(_nm_keys)]
                    if len(_nm_matched) > 0:
                        _nm_snap_balances[sk] = _nm_matched['balance'].mean()

        print(f"  Never Mailed control: {_nm_n:,} accounts, "
              f"balance at {len(_nm_snap_balances)} snapshots")

    # Discover snapshots with balance data
    _snap_bal_cols = {sk: f"{sk}_balance" for sk in SNAPSHOT_ORDER
                      if f"{sk}_balance" in _cohort.columns}

    if len(_snap_bal_cols) < 2:
        print(f"    Need at least 2 snapshots. Found: {list(_snap_bal_cols.keys())}")
    else:
        _mailers = sorted(_cohort['mailer'].unique(),
                           key=lambda m: pd.to_datetime(m, format='%b%y'))

        _snap_dates_local = {}
        if 'SNAPSHOT_CONFIG' in dir():
            for sk in SNAPSHOT_ORDER:
                cfg = SNAPSHOT_CONFIG[sk]
                try:
                    _snap_dates_local[sk] = pd.to_datetime(
                        cfg['label'], format='%b %Y')
                except (ValueError, KeyError):
                    if 'sort_key' in cfg:
                        _snap_dates_local[sk] = pd.Timestamp(
                            year=cfg['sort_key'] // 100,
                            month=cfg['sort_key'] % 100, day=1)

        _seg_colors = {
            'NU':    GEN_COLORS['info'],
            'TH-10': '#2EC4B6',
            'TH-15': '#20A39E',
            'TH-20': '#1B8A7A',
            'TH-25': GEN_COLORS['primary'],
        }

        # ---------------------------------------------------------------
        # One full-size chart per mailer
        # ---------------------------------------------------------------
        for mailer in _mailers:
            _mdf = _cohort[_cohort['mailer'] == mailer]
            _wave_date = _mdf['wave_date'].iloc[0]

            # Valid snapshots for this mailer
            _valid_snaps = []
            _snap_labels = []
            for sk, col in _snap_bal_cols.items():
                if sk not in _snap_dates_local:
                    continue
                if _mdf[col].notna().sum() == 0:
                    continue
                _sd = _snap_dates_local[sk]
                _months = ((_sd.year - _wave_date.year) * 12
                           + (_sd.month - _wave_date.month))
                _cfg_label = (SNAPSHOT_CONFIG[sk]['label']
                              if 'SNAPSHOT_CONFIG' in dir()
                              and sk in SNAPSHOT_CONFIG else sk)
                _rel = (f"{abs(_months)}mo before" if _months < 0
                        else "at mailer" if _months == 0
                        else f"{_months}mo after")
                _valid_snaps.append(sk)
                _snap_labels.append(f"{_cfg_label}\n({_rel})")

            if len(_valid_snaps) < 2:
                continue

            # Top segments by account count for this mailer
            _seg_counts = (_mdf['segment'].value_counts()
                           .reindex(SEGMENT_ORDER).dropna())
            _top_segs = [s for s in SEGMENT_ORDER
                         if s in _seg_counts.index and _seg_counts[s] > 0]

            fig, ax = plt.subplots(figsize=(14, 7))
            _x = range(len(_valid_snaps))

            for seg in _top_segs:
                _seg_data = _mdf[_mdf['segment'] == seg]
                _color = _seg_colors.get(seg, GEN_COLORS['muted'])

                for outcome, ls, lw, alpha, marker in [
                    ('Responder', '-', 2.5, 1.0, 'o'),
                    ('Non-Responder', '--', 1.8, 0.6, 's')
                ]:
                    _out = _seg_data[_seg_data['outcome'] == outcome]
                    if len(_out) < 5:
                        continue
                    _vals = [_out[_snap_bal_cols[sk]].mean()
                             for sk in _valid_snaps]
                    if all(pd.isna(v) for v in _vals):
                        continue

                    _lbl = (f"{seg} Resp ({len(_out):,})"
                            if outcome == 'Responder'
                            else f"{seg} NR ({len(_out):,})")
                    ax.plot(_x, _vals, color=_color, linewidth=lw,
                            linestyle=ls, alpha=alpha, marker=marker,
                            markersize=7, markeredgecolor='white',
                            markeredgewidth=1.5, label=_lbl,
                            zorder=5 if outcome == 'Responder' else 3)

                    # Label last point
                    _last = _vals[-1]
                    if pd.notna(_last):
                        ax.text(len(_valid_snaps) - 1 + 0.08, _last,
                                gen_fmt_dollar(_last, None),
                                fontsize=9, fontweight='bold', va='center',
                                color=_color, alpha=alpha)

            # Never Mailed baseline
            if _nm_snap_balances:
                _nm_vals = [_nm_snap_balances.get(sk, np.nan)
                            for sk in _valid_snaps]
                if any(pd.notna(v) for v in _nm_vals):
                    ax.plot(_x, _nm_vals, color=GEN_COLORS['warning'],
                            linewidth=2, linestyle=':', marker='D',
                            markersize=5, markeredgecolor='white',
                            markeredgewidth=1,
                            label=f'Never Mailed ({_nm_n:,})', zorder=2)

            # Mark closest-to-mailer snapshot
            for i, sk in enumerate(_valid_snaps):
                if sk in _snap_dates_local:
                    _sd = _snap_dates_local[sk]
                    _diff = abs((_sd.year - _wave_date.year) * 12
                                + (_sd.month - _wave_date.month))
                    if _diff <= 1:
                        ax.axvline(x=i, color=GEN_COLORS['accent'],
                                   linewidth=1.5, linestyle=':', alpha=0.5)

            ax.set_xticks(list(_x))
            ax.set_xticklabels(_snap_labels, fontsize=12, fontweight='bold')
            ax.set_ylabel("Avg Deposit Balance", fontsize=16,
                           fontweight='bold', labelpad=10)
            ax.yaxis.set_major_formatter(mticker.FuncFormatter(gen_fmt_dollar))
            gen_clean_axes(ax)
            ax.yaxis.grid(True, color=GEN_COLORS['grid'],
                           linewidth=0.5, alpha=0.7)
            ax.set_axisbelow(True)

            ax.set_title(f"{mailer} Mailer: Deposit Balance by Segment",
                          fontsize=24, fontweight='bold',
                          color=GEN_COLORS['dark_text'], pad=15)
            ax.text(0.0, 1.02,
                    f"{len(_mdf):,} mailed  |  "
                    f"Solid = responded, Dashed = did not  |  "
                    f"Dotted amber = never mailed",
                    transform=ax.transAxes, fontsize=12,
                    color=GEN_COLORS['muted'], style='italic')

            # Legend outside right
            ax.legend(fontsize=9, loc='center left',
                      bbox_to_anchor=(1.01, 0.5), frameon=True,
                      facecolor='white', edgecolor=GEN_COLORS['grid'])

            plt.tight_layout()
            plt.show()

        # ---------------------------------------------------------------
        # DID table: deposit growth by segment x mailer
        # ---------------------------------------------------------------
        _did_rows = []

        _nm_delta = np.nan
        _snap_keys_sorted = sorted(
            _nm_snap_balances.keys(),
            key=lambda k: _snap_dates_local.get(k, pd.Timestamp.min))
        if len(_snap_keys_sorted) >= 2:
            _nm_delta = (_nm_snap_balances[_snap_keys_sorted[-1]]
                         - _nm_snap_balances[_snap_keys_sorted[0]])

        def _build_did(data, mailer_label):
            _bs = (data['before_snap'].dropna().iloc[0]
                   if data['before_snap'].notna().any() else None)
            _as = (data['after_snap'].dropna().iloc[0]
                   if data['after_snap'].notna().any() else None)
            if not _bs or not _as:
                return
            _b_col, _a_col = f"{_bs}_balance", f"{_as}_balance"
            if _b_col not in data.columns or _a_col not in data.columns:
                return

            for seg in SEGMENT_ORDER:
                _seg = data[data['segment'] == seg]
                _r = _seg[_seg['outcome'] == 'Responder']
                _nr = _seg[_seg['outcome'] == 'Non-Responder']
                if len(_r) == 0 and len(_nr) == 0:
                    continue

                _r_b = _r[_b_col].mean() if len(_r) > 0 else np.nan
                _r_a = _r[_a_col].mean() if len(_r) > 0 else np.nan
                _nr_b = _nr[_b_col].mean() if len(_nr) > 0 else np.nan
                _nr_a = _nr[_a_col].mean() if len(_nr) > 0 else np.nan
                _r_d = _r_a - _r_b if pd.notna(_r_a) and pd.notna(_r_b) else np.nan
                _nr_d = _nr_a - _nr_b if pd.notna(_nr_a) and pd.notna(_nr_b) else np.nan
                _did = _r_d - _nr_d if pd.notna(_r_d) and pd.notna(_nr_d) else np.nan

                _did_rows.append({
                    'Segment': seg, 'Mailer': mailer_label,
                    'Resp N': len(_r),
                    'Resp Before': _r_b, 'Resp After': _r_a,
                    'Resp Delta': _r_d,
                    'NR N': len(_nr), 'NR Delta': _nr_d,
                    'NM Delta': _nm_delta, 'DID Lift': _did,
                })

        # Aggregate
        for seg in SEGMENT_ORDER:
            _s = _cohort[_cohort['segment'] == seg]
            _r = _s[_s['outcome'] == 'Responder']
            _nr = _s[_s['outcome'] == 'Non-Responder']
            if len(_r) == 0 and len(_nr) == 0:
                continue
            _r_d = _r['delta_balance'].mean() if 'delta_balance' in _r.columns and len(_r) > 0 else np.nan
            _nr_d = _nr['delta_balance'].mean() if 'delta_balance' in _nr.columns and len(_nr) > 0 else np.nan
            _did = _r_d - _nr_d if pd.notna(_r_d) and pd.notna(_nr_d) else np.nan
            _did_rows.append({
                'Segment': seg, 'Mailer': 'ALL MAILERS',
                'Resp N': len(_r), 'Resp Delta': _r_d,
                'NR N': len(_nr), 'NR Delta': _nr_d,
                'NM Delta': _nm_delta, 'DID Lift': _did,
            })

        for mailer in _mailers:
            _build_did(_cohort[_cohort['mailer'] == mailer], mailer)

        _did_df = pd.DataFrame(_did_rows)

        if len(_did_df) > 0:
            _disp_cols = ['Segment', 'Mailer', 'Resp N',
                          'Resp Before', 'Resp After', 'Resp Delta',
                          'NR N', 'NR Delta', 'NM Delta', 'DID Lift']
            _disp_cols = [c for c in _disp_cols if c in _did_df.columns]
            _display_df = _did_df[_disp_cols].copy()

            _seg_breaks = set()
            _prev = None
            for i, row in _display_df.iterrows():
                if row['Segment'] != _prev and _prev is not None:
                    _seg_breaks.add(i)
                _prev = row['Segment']

            _agg_idx = set(
                _display_df[_display_df['Mailer'] == 'ALL MAILERS'].index)

            def _style_rows(row):
                is_agg = row.name in _agg_idx
                is_break = row.name in _seg_breaks
                parts = []
                if is_agg:
                    parts.append('font-weight: bold')
                    parts.append('background-color: rgba(27, 42, 74, 0.05)')
                if is_break:
                    parts.append('border-top: 2px solid #1B2A4A')
                css = '; '.join(parts) if parts else ''
                return [css] * len(row)

            def _color_deltas(col):
                if col.name not in ('DID Lift', 'Resp Delta', 'NR Delta', 'NM Delta'):
                    return [''] * len(col)
                return [
                    f'color: {GEN_COLORS["success"]}' if pd.notna(v) and v > 0
                    else f'color: {GEN_COLORS["accent"]}' if pd.notna(v) and v < 0
                    else ''
                    for v in col
                ]

            def _fmt_d(v):
                if pd.isna(v): return '--'
                return f"{'+'if v >= 0 else '-'}${abs(v):,.0f}"

            _fmt = {
                'Resp N': '{:,.0f}', 'NR N': '{:,.0f}',
                'Resp Before': '${:,.0f}', 'Resp After': '${:,.0f}',
                'Resp Delta': _fmt_d, 'NR Delta': _fmt_d,
                'NM Delta': _fmt_d, 'DID Lift': _fmt_d,
            }

            _styled = (
                _display_df.style
                .hide(axis='index')
                .format(_fmt, na_rep='--')
                .apply(_style_rows, axis=1)
                .apply(_color_deltas)
                .set_properties(**{
                    'font-size': '12px', 'text-align': 'center',
                    'border': '1px solid #E9ECEF', 'padding': '7px 10px',
                })
                .set_properties(subset=['Segment'], **{
                    'font-weight': 'bold', 'text-align': 'left',
                    'color': GEN_COLORS['primary'],
                })
                .set_properties(subset=['Mailer'], **{'text-align': 'left'})
                .set_table_styles([
                    {'selector': 'th', 'props': [
                        ('background-color', GEN_COLORS['primary']),
                        ('color', 'white'), ('font-size', '12px'),
                        ('font-weight', 'bold'), ('text-align', 'center'),
                        ('padding', '8px'),
                    ]},
                    {'selector': 'caption', 'props': [
                        ('font-size', '22px'), ('font-weight', 'bold'),
                        ('color', GEN_COLORS['dark_text']),
                        ('text-align', 'left'), ('padding-bottom', '12px'),
                    ]},
                ])
                .set_caption("Deposit Growth: Resp vs NR by Segment x Mailer")
            )
            display(_styled)

            # Narrative
            _agg = _did_df[_did_df['Mailer'] == 'ALL MAILERS']
            if len(_agg) > 0:
                print(f"\n  Deposit DID (all mailers pooled):")
                _pos = 0
                for _, row in _agg.iterrows():
                    _d = row.get('DID Lift')
                    if pd.notna(_d):
                        print(f"    {row['Segment']:<8s}: "
                              f"{'+'if _d >= 0 else '-'}${abs(_d):,.0f}  "
                              f"({'DEPOSITS UP' if _d > 0 else 'FLAT/DOWN'})")
                        _pos += _d > 0
                print(f"\n    {_pos}/{len(_agg)} segments show positive "
                      f"deposit lift from responding")
