        return False
    v = str(val).strip().upper()
    if v.startswith('TH'):
        return True
    if v in ('NU 5+', 'NU5+', 'NU 5', 'NU 6', 'NU 7', 'NU 8', 'NU 9', 'NU 10'):
        return True
    return False

def _is_nu_partial(val):
    if pd.isna(val):
        return False
    v = str(val).strip().upper()
    return v in ('NU 1-4', 'NU1-4')

_resp_col_list = [_resp_cols[k] for k in _mailer_keys]
_mail_col_list = [_mail_cols[k] for k in _mailer_keys]

_times_mailed = _df[_mail_col_list].notna().sum(axis=1)
_times_success = _df[_resp_col_list].apply(
    lambda col: col.map(_is_success)).sum(axis=1)
_times_nu14 = _df[_resp_col_list].apply(
    lambda col: col.map(_is_nu_partial)).sum(axis=1)

_df['_camp_status'] = 'Never Mailed'
_df.loc[_times_mailed > 0, '_camp_status'] = 'Non-Responder'
_df.loc[_times_nu14 > 0, '_camp_status'] = 'NU 1-4 (Partial)'
_df.loc[_times_success > 0, '_camp_status'] = 'Responder'

_camp_groups = ['Responder', 'NU 1-4 (Partial)', 'Non-Responder']
_camp_groups = [g for g in _camp_groups if g in _df['_camp_status'].values]
_total = len(_df)

_has_spend = bool(_spend_cols)
_has_mtd = bool(_mtd_cols)

if (_has_spend or _has_mtd) and len(_camp_groups) >= 2:
    _n_charts = int(_has_spend) + int(_has_mtd)
    fig, axes = plt.subplots(1, _n_charts, figsize=(16, 7) if _n_charts == 1
                             else (9 * _n_charts, 7))
