    ]:
        if not _metric_cols:
            continue
        ax = axes[_chart_idx]
        _chart_idx += 1
        _m_keys = sorted(_metric_cols.keys(), key=_msort)
        _x_labels = [f"{mk[:3]} '{mk[3:]}" for mk in _m_keys]

        for g in _camp_groups:
            _g_df = _df[_df['_camp_status'] == g]
