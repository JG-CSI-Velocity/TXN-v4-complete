# ===========================================================================
# PERSONAL DEPOSITS: Monthly Spend & Deposit Trend by Campaign Status
# ===========================================================================
# Shows median monthly Card Spend and MTD (deposits) per campaign status
# group over all 36 monthly periods. Mailer periods marked as dashed lines.
#
# Depends on cell 14 classification (_df with _camp_status already assigned).
# Cross-source: ODDD (monthly Spend/MTD cols, Mail/Resp cols)
# Data: deposits_personal_df (via _df from cell 14)

import matplotlib.pyplot as plt
import matplotlib.ticker as mticker
import numpy as np
import re

_df = deposits_personal_df.copy()

# ---- Discover column families ----
_mail_pattern = re.compile(r'^([A-Z][a-z]{2}\d{2})\s+Mail$')
_resp_pattern = re.compile(r'^([A-Z][a-z]{2}\d{2})\s+Resp$')
_spend_pattern = re.compile(r'^([A-Z][a-z]{2}\d{2})\s+Spend$')
_mtd_pattern = re.compile(r'^([A-Z][a-z]{2}\d{2})\s+MTD$')

_mail_cols = {}
_resp_cols = {}
_spend_cols = {}
_mtd_cols = {}

for col in _df.columns:
    for pat, target in [(_mail_pattern, _mail_cols), (_resp_pattern, _resp_cols),
                        (_spend_pattern, _spend_cols), (_mtd_pattern, _mtd_cols)]:
        m = pat.match(col)
        if m:
            target[m.group(1)] = col
            break

_month_order = {'Jan':1,'Feb':2,'Mar':3,'Apr':4,'May':5,'Jun':6,
                'Jul':7,'Aug':8,'Sep':9,'Oct':10,'Nov':11,'Dec':12}
def _msort(k):
    return (int(k[3:])+2000, _month_order.get(k[:3], 0))

_mailer_keys = sorted([k for k in _mail_cols if k in _resp_cols], key=_msort)

# ---- Classification (same as cell 14) ----
