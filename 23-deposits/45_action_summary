# ---------------------------------------------------------------------------
# 1. Dynamically computed insights
# ---------------------------------------------------------------------------
_insights = []

# Overall response rate
if 'wave_cohort_df' in dir() and len(wave_cohort_df) > 0:
    _total = len(wave_cohort_df)
    _hits = (wave_cohort_df['outcome'] == 'Responder').sum()
    _rate = _hits / _total * 100 if _total > 0 else 0
    _insights.append({
        'Metric': 'Overall Response Rate',
        'Value': f"{_rate:.1f}%",
        'Detail': f"{_hits:,} hit responses out of {_total:,} account-waves",
    })

# Best-performing segment
if 'wave_cohort_df' in dir() and len(wave_cohort_df) > 0:
    _ch_rates = wave_cohort_df.groupby('segment').agg(
        total=('outcome', 'count'),
        hits=('outcome', lambda x: (x == 'Responder').sum()),
    ).reset_index()
    _ch_rates['rate'] = _ch_rates['hits'] / _ch_rates['total'] * 100
    _best = _ch_rates.loc[_ch_rates['rate'].idxmax()]
    _insights.append({
        'Metric': 'Best Segment',
        'Value': f"{_best['segment']} ({_best['rate']:.1f}%)",
        'Detail': f"{int(_best['hits']):,} hits from {int(_best['total']):,} mailings",
    })

# Deposit gap (responder vs non)
if 'wave_cohort_df' in dir() and 'balance' in wave_cohort_df.columns:
    _h_bal = wave_cohort_df[wave_cohort_df['outcome'] == 'Responder']['balance'].mean()
    _n_bal = wave_cohort_df[wave_cohort_df['outcome'] == 'Non-Responder']['balance'].mean()
    _insights.append({
        'Metric': 'Deposit Balance Gap',
        'Value': f"${_h_bal - _n_bal:+,.0f}",
        'Detail': f"Responders ${_h_bal:,.0f} vs non-responders ${_n_bal:,.0f}",
    })

# Spend lift
if 'wave_cohort_df' in dir() and 'spend_delta' in wave_cohort_df.columns:
    _h_delta = wave_cohort_df[wave_cohort_df['outcome'] == 'Responder']['spend_delta'].mean()
    _n_delta = wave_cohort_df[wave_cohort_df['outcome'] == 'Non-Responder']['spend_delta'].mean()
    _insights.append({
        'Metric': 'Avg Spend Lift (Hit)',
        'Value': f"${_h_delta:+,.0f}/mo",
        'Detail': f"vs ${_n_delta:+,.0f}/mo for non-responders (same segment)",
    })

# Repeat responders
if 'response_journey_df' in dir() and len(response_journey_df) > 0:
    _any_resp = (response_journey_df['times_responded'] > 0).sum()
    _repeat = response_journey_df['is_repeat_responder'].sum()
    _pct = _repeat / _any_resp * 100 if _any_resp > 0 else 0
    _insights.append({
        'Metric': 'Repeat Responders',
        'Value': f"{_pct:.1f}%",
        'Detail': f"{_repeat:,} of {_any_resp:,} responders hit in multiple waves",
    })

# DD predictor
if 'wave_cohort_df' in dir() and 'has_direct_deposit' in wave_cohort_df.columns:
    _dd = wave_cohort_df[wave_cohort_df['has_direct_deposit'] == True]
    _no_dd = wave_cohort_df[wave_cohort_df['has_direct_deposit'] == False]
    _dd_r = (_dd['outcome'] == 'Responder').mean() * 100 if len(_dd) > 0 else 0
    _no_dd_r = (_no_dd['outcome'] == 'Responder').mean() * 100 if len(_no_dd) > 0 else 0
    _mult = _dd_r / _no_dd_r if _no_dd_r > 0 else 0
    _insights.append({
        'Metric': 'DD Response Multiplier',
        'Value': f"{_mult:.2f}x",
        'Detail': f"DD members: {_dd_r:.1f}% vs non-DD: {_no_dd_r:.1f}%",
    })

