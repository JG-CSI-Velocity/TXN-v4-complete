    </p>
"""

# Insights table
if _insights:
    _html += f"""
    <h3 style="color: {_primary}; font-size: 18px; margin-top: 20px; margin-bottom: 8px;">
        Key Findings
    </h3>
    <table style="border-collapse: collapse; width: 100%; font-size: 13px; margin-bottom: 30px;">
        <thead>
            <tr style="background-color: {_primary}; color: white;">
                <th style="padding: 10px 12px; text-align: left; width: 20%;">Metric</th>
