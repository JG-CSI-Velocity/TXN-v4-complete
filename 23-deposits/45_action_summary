    _html += f"""
        <tr style="background-color: {_bg};">
            <td style="padding: 10px 12px; font-weight: bold; border-bottom: 1px solid #e0e0e0;">{i + 1}</td>
            <td style="padding: 10px 12px; font-weight: bold; border-bottom: 1px solid #e0e0e0;">{act['Action']}</td>
            <td style="padding: 10px 12px; color: #555; border-bottom: 1px solid #e0e0e0;">{act['Rationale']}</td>
