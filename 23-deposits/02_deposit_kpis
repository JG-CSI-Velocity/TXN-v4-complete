    {
        'label': 'Active Rate',
        'value': f"{_active_pct:.1f}%",
        'signal': f"{_dep_365:,} of {_total:,}",
        'color': _signal_color(_active_pct, 70, 50),
    },
    {
        'label': 'ACH / Direct Deposit',
        'value': f"{_ach_pct:.1f}%",
        'signal': f"{_auto_flag.sum():,} accounts",
        'color': _signal_color(_ach_pct, 40, 20),
    },
    {
        'label': 'Median Balance',
        'value': f"${_median_bal:,.0f}" if not np.isnan(_median_bal) else 'N/A',
        'signal': 'Active depositors (365d)',
        'color': _CLR_NEUTRAL,
    },
    {
        'label': 'Avg Annual Deposit',
        'value': f"${_avg_dep:,.0f}" if not np.isnan(_avg_dep) else 'N/A',
        'signal': 'Active depositors (365d)',
        'color': _CLR_NEUTRAL,
    },
]

for idx, m in enumerate(_health_metrics):
    ax = fig.add_subplot(_gs_health[idx])
    ax.set_xlim(0, 1)
    ax.set_ylim(0, 1)
    ax.axis('off')
    ax.add_patch(FancyBboxPatch(
        (0.02, 0.02), 0.96, 0.96,
        boxstyle="round,pad=0.04",
        facecolor='white', edgecolor=m['color'], linewidth=3.5))
    # Colored left accent bar
    ax.add_patch(FancyBboxPatch(
        (0.02, 0.02), 0.06, 0.96,
        boxstyle="round,pad=0.01",
        facecolor=m['color'], edgecolor='none'))
    ax.text(0.55, 0.78, m['label'], transform=ax.transAxes,
            ha='center', va='center', fontsize=14, fontweight='bold',
            color=GEN_COLORS['muted'])
    ax.text(0.55, 0.45, m['value'], transform=ax.transAxes,
            ha='center', va='center', fontsize=26, fontweight='bold',
            color=m['color'])
    ax.text(0.55, 0.15, m['signal'], transform=ax.transAxes,
            ha='center', va='center', fontsize=12, fontweight='medium',
            color=GEN_COLORS['muted'])

# =====================================================================
# ROW 2: Activity Segmentation — horizontal bars with full annotation
# =====================================================================
ax_seg = fig.add_subplot(gs[1])

_seg_data = [
    {
        'label': 'Recent Depositors (33d)',
        'count': _dep_33,
        'bal': _bal_recent,
        'color': _CLR_HEALTHY,
        'dep_share': _conc_recent,
    },
    {
        'label': 'Active, Not Recent (34\u2013365d)',
        'count': _active_not_recent,
