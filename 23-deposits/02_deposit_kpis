        'color': _CLR_CAUTION,
        'dep_share': _conc_active_nr,
    },
    {
        'label': 'Inactive (No deposits 365d)',
        'count': _inactive_365,
        'bal': _bal_inactive,
        'color': _CLR_PROBLEM,
        'dep_share': 0.0,
