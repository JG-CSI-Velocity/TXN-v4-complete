    _parts = [f"{seg['count']:,} accounts"]
    if not np.isnan(seg['bal']):
        _parts.append(f"Median: ${seg['bal']:,.0f}")
    if seg['dep_share'] and not np.isnan(seg['dep_share']) and seg['dep_share'] > 0:
        _parts.append(f"{seg['dep_share']:.1f}% of deposits")
