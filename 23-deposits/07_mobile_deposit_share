# ===========================================================================
# PERSONAL DEPOSITS: Mobile Deposit Share
# ===========================================================================
# What share of deposits are mobile? Mobile_Deposits_90 / DepCount99
# Shows distribution of mobile deposit share per account.
# Data: deposits_personal_df (ZAccounts fields)

import matplotlib.pyplot as plt
import matplotlib.ticker as mticker
import numpy as np

_df = deposits_personal_df.copy()
_mobile_field = 'Mobile_Deposits_90'
_total_field = 'DepCount99'

if _mobile_field not in _df.columns or _total_field not in _df.columns:
    print(f"    WARNING: Missing '{_mobile_field}' or '{_total_field}' -- skipping")
else:
    # Filter to accounts with at least 1 deposit in 99 days
    _df = _df[_df[_total_field] > 0].copy()
    _total = len(_df)

    _df['mobile_share'] = (_df[_mobile_field] / _df[_total_field]).clip(0, 1)
    _has_mobile = (_df[_mobile_field] > 0).sum()
    _median_share = _df.loc[_df[_mobile_field] > 0, 'mobile_share'].median()

    print(f"    07 Data Decisions:")
    print(f"      Source: deposits_personal_df (open personal accounts)")
    print(f"      Fields: {_mobile_field} / {_total_field}")
    print(f"      Accounts with 99d deposits: {_total:,}")
    print(f"      Accounts with mobile deposits: {_has_mobile:,} ({_has_mobile/_total*100:.1f}%)")
    print(f"      Median mobile share (among mobile users): {_median_share:.1%}" if _has_mobile else "")

    # Bin mobile share into categories
    _bins = [0, 0.001, 0.25, 0.50, 0.75, 1.01]
    _labels = ['No Mobile (0%)', '1-25%', '26-50%', '51-75%', '76-100%']
    _df['mobile_bin'] = pd.cut(_df['mobile_share'], bins=_bins, labels=_labels, right=False)
    _bin_counts = _df['mobile_bin'].value_counts().reindex(_labels).fillna(0).astype(int)

    _bin_colors = [
        GEN_COLORS['muted'],
        GEN_COLORS['info'],
        GEN_COLORS['warning'],
        GEN_COLORS['success'],
        GEN_COLORS['accent'],
    ]

    # ---------------------------------------------------------------------------
    # Chart: Horizontal bar of mobile deposit share bins
    # ---------------------------------------------------------------------------
    fig, ax = plt.subplots(figsize=(14, 7))

    _bars = ax.barh(_labels[::-1], _bin_counts.values[::-1],
                    color=_bin_colors[::-1], edgecolor='white', height=0.55)

    for bar, val in zip(_bars, _bin_counts.values[::-1]):
        _pct = val / _total * 100
        ax.text(bar.get_width() + _total * 0.01, bar.get_y() + bar.get_height() / 2,
                f"{val:,}  ({_pct:.1f}%)",
                ha='left', va='center', fontsize=15, fontweight='bold',
                color=GEN_COLORS['dark_text'])

    ax.set_title('Personal Accounts \u2014 Mobile Deposit Share',
                 fontsize=22, fontweight='bold', color=GEN_COLORS['dark_text'], pad=15)
