    ax.xaxis.set_major_formatter(mticker.FuncFormatter(gen_fmt_count))
    ax.tick_params(axis='y', labelsize=14)
    ax.tick_params(axis='x', labelsize=14)

    _sub = f"{_has_mobile:,} of {_total:,} depositors use mobile  |  Mobile_Deposits_90 / DepCount99"
    ax.text(0.5, -0.10, _sub, transform=ax.transAxes, ha='center',
            fontsize=12, color=GEN_COLORS['muted'])

    gen_clean_axes(ax)
    plt.tight_layout()
    plt.show()
