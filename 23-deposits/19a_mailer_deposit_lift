# ===========================================================================
# MAILER DEPOSIT LIFT: Pre vs Post Deposits Around Each Mailer Wave
# ===========================================================================
# Shows deposit changes after each mailer, broken out by response segment.
#
# Multi-snapshot mode (primary): With 2+ Z files (e.g., Mar25 + Mar26),
#   every mailer between them gets a pre vs post comparison using depAmt365/12.
#   Matches accounts across snapshots using _join_key (acctid), NOT
#   HASHED_ACCOUNT (which can differ between snapshot files).
#
# Single-snapshot supplement: Uses DepAmt365 as baseline and DepAmt33 as
#   recent reading. For any mailer in the last ~11 months, DepAmt365/12
#   includes pre-mailer months while DepAmt33 is post-mailer.
#   Also uses 99/66/33 day readings for fine-grained recent analysis.
#
# Both modes break out by mailer wave AND response segment.
#
# Depends on: _acct (cell 04), rewards_df, mail_cols, resp_cols,
#             SNAPSHOT_CONFIG, SNAPSHOT_ORDER, deposit_long (if multi-snap),
#             DEPOSIT_JOIN_KEY_DEPOSIT, DEPOSIT_JOIN_KEY_ODDD (from cell 01),
#             GEN_COLORS, DATASET_LABEL

if '_acct' not in dir():
    print("    Run cell 04 first.")
elif 'mail_cols' not in dir() or 'resp_cols' not in dir():
    print("    No mail/resp columns. Run 09-ars-campaign cell 01 first.")
else:
    from IPython.display import display

    # -----------------------------------------------------------------
    # Helpers
    # -----------------------------------------------------------------
    def _parse_segment(val):
        if pd.isna(val): return None
        v = str(val).strip().upper()
        if v.startswith('TH-'): return v
        if v.startswith('TH') and len(v) > 2 and v[2:].strip('-').isdigit():
            return f"TH-{v[2:].strip('-')}"
        if v in ('NU 5+', 'NU5+', 'NU 5', 'NU 6', 'NU 7', 'NU 8', 'NU 9', 'NU 10'):
            return 'NU 5+'
        if v in ('NU 1-4', 'NU1-4'): return 'NU 1-4'
        if v in ('10', '15', '20', '25'): return f"TH-{v}"
        return None

    def _is_success(val):
        if pd.isna(val): return False
        v = str(val).strip().upper()
        if v.startswith('TH'): return True
        return v in ('NU 5+', 'NU5+', 'NU 5', 'NU 6', 'NU 7', 'NU 8', 'NU 9', 'NU 10')

    def _color_change(col):
        return [f'color: {GEN_COLORS["success"]}; font-weight: bold'
                if pd.notna(v) and v > 0
                else f'color: {GEN_COLORS["accent"]}; font-weight: bold'
                if pd.notna(v) and v < 0
                else '' for v in col]

    def _display_table(df, caption, change_cols=None):
        if change_cols is None:
            change_cols = [c for c in ['Change $', 'Change %'] if c in df.columns]
        _fmt = {}
        for c in df.columns:
            if c in ('N', 'Pre Points', 'Post Points'): _fmt[c] = '{:,.0f}'
            elif 'Dep $' in c and 'Change' not in c: _fmt[c] = '${:,.0f}'
            elif c == 'Change $': _fmt[c] = '${:+,.0f}'
            elif '%' in c: _fmt[c] = '{:+.1f}%'
            elif 'Ct' in c: _fmt[c] = '{:,.1f}'

        _text_cols = [c for c in df.columns if df[c].dtype == 'object']
        _styled = (
            df.style.hide(axis='index')
            .format({k: v for k, v in _fmt.items() if k in df.columns}, na_rep='--')
            .apply(_color_change, subset=[c for c in change_cols if c in df.columns])
            .set_properties(**{'font-size': '13px', 'font-weight': 'bold',
                'text-align': 'center', 'border': '1px solid #E9ECEF', 'padding': '8px 10px'})
            .set_table_styles([
                {'selector': 'th', 'props': [('background-color', GEN_COLORS['primary']),
                    ('color', 'white'), ('font-size', '13px'), ('font-weight', 'bold'),
                    ('text-align', 'center'), ('padding', '8px 10px')]},
                {'selector': 'caption', 'props': [('font-size', '22px'), ('font-weight', 'bold'),
                    ('color', GEN_COLORS['dark_text']), ('text-align', 'left'), ('padding-bottom', '12px')]},
            ])
            .set_caption(caption)
        )
        for tc in _text_cols:
            _styled = _styled.set_properties(subset=[tc], **{'text-align': 'left'})
        display(_styled)

    def _make_wave_row(label, n, pre_med, post_med, extra=None):
        row = {
            'Mailer': label, 'N': n,
            'Pre Med Dep $': pre_med, 'Post Med Dep $': post_med,
            'Change $': post_med - pre_med,
            'Change %': ((post_med - pre_med) / pre_med * 100) if pre_med > 0 else 0,
        }
        if extra:
            row.update(extra)
        return row

    def _make_chart(wdf, title, subtitle):
        fig, ax = plt.subplots(figsize=(max(12, len(wdf) * 2.5), 7))
        x = np.arange(len(wdf))
        w = 0.3
        ax.bar(x - w/2, wdf['Pre Med Dep $'], w, label='Pre-Mailer',
               color=GEN_COLORS['muted'], edgecolor='white', linewidth=1)
        ax.bar(x + w/2, wdf['Post Med Dep $'], w, label='Post-Mailer',
               color=GEN_COLORS['success'], edgecolor='white', linewidth=1)
        for i, row in wdf.iterrows():
            _top = max(row['Pre Med Dep $'], row['Post Med Dep $'])
            _d, _p = row['Change $'], row['Change %']
            _s = '+' if _d >= 0 else ''
            _c = GEN_COLORS['success'] if _d >= 0 else GEN_COLORS['accent']
            ax.text(i, _top * 1.03, f"{_s}${_d:,.0f} ({_s}{_p:.1f}%)",
                    ha='center', va='bottom', fontsize=13, fontweight='bold', color=_c)
        ax.set_xticks(x)
        ax.set_xticklabels(wdf['Mailer'], fontsize=14, fontweight='bold', rotation=45, ha='right')
        ax.set_ylabel("Median Monthly Deposits ($/mo)", fontsize=16, fontweight='bold')
        ax.yaxis.set_major_formatter(mticker.FuncFormatter(gen_fmt_count))
        ax.legend(fontsize=14)
        gen_clean_axes(ax, keep_left=True, keep_bottom=True)
        ax.yaxis.grid(True, color=GEN_COLORS.get('grid', '#E0E0E0'), linewidth=0.5, alpha=0.7)
        ax.set_axisbelow(True)
        fig.suptitle(title, fontsize=26, fontweight='bold', color=GEN_COLORS['dark_text'], y=0.98)
        fig.text(0.5, 0.93, subtitle,
                 ha='center', fontsize=14, color=GEN_COLORS['muted'], style='italic')
        plt.tight_layout(rect=[0, 0, 1, 0.91])
        plt.show()

    # -----------------------------------------------------------------
    # Determine ODDD join key (what column in rewards_df maps to acctid)
    # -----------------------------------------------------------------
    if 'DEPOSIT_JOIN_KEY_ODDD' in dir():
        _oddd_key = DEPOSIT_JOIN_KEY_ODDD
    else:
        # Try common columns
        _oddd_key = None
        for _try in ['Acct ID', 'Acct Number', ' Acct Number']:
            if _try in rewards_df.columns:
                _oddd_key = _try
                break
    if _oddd_key is None:
        _oddd_key = 'Acct Number' if 'Acct Number' in rewards_df.columns else rewards_df.columns[0]

    print(f"  ODDD join key: {_oddd_key}")

    # =================================================================
    # MULTI-SNAPSHOT MODE: compare depAmt365 across Z files
    # =================================================================
    _multi = ('deposit_long' in dir() and len(deposit_long) > 0
              and 'SNAPSHOT_ORDER' in dir() and len(SNAPSHOT_ORDER) >= 2)

    if _multi:
        print("\n  === Multi-Snapshot Analysis ===")

        _snap_dates = {}
        for sk in SNAPSHOT_ORDER:
            sc = SNAPSHOT_CONFIG[sk]
            _sort = sc['sort_key']
            _snap_dates[sk] = pd.Timestamp(year=_sort // 100, month=_sort % 100, day=15)

        print(f"  Snapshots: {', '.join(f'{k} ({v.strftime('%b %Y')})' for k, v in _snap_dates.items())}")

        _snap_keys = list(_snap_dates.keys())
        _snap_ts = list(_snap_dates.values())

        # Use _join_key in deposit_long (= acctid) to match across snapshots
        # HASHED_ACCOUNT differs between files, _join_key/acctid should be stable
        _dep_key = '_join_key' if '_join_key' in deposit_long.columns else 'acctid'
        if _dep_key not in deposit_long.columns:
            _dep_key = 'HASHED_ACCOUNT'

        # Verify cross-snapshot matching works
        _snap_sets = {}
        for sk in _snap_keys:
            _snap_sets[sk] = set(deposit_long.loc[deposit_long['snapshot'] == sk, _dep_key].dropna())
        _overlap = _snap_sets[_snap_keys[0]]
        for sk in _snap_keys[1:]:
            _overlap = _overlap & _snap_sets[sk]
        print(f"  Matching key: {_dep_key}")
        print(f"  Accounts in {_snap_keys[0]}: {len(_snap_sets[_snap_keys[0]]):,}")
        print(f"  Accounts in {_snap_keys[-1]}: {len(_snap_sets[_snap_keys[-1]]):,}")
        print(f"  Matched across all snapshots: {len(_overlap):,}")

        if len(_overlap) == 0:
            print(f"\n  WARNING: 0 accounts match across snapshots using '{_dep_key}'.")
            print(f"  Trying 'acctid' directly...")
            if 'acctid' in deposit_long.columns and _dep_key != 'acctid':
                _dep_key = 'acctid'
                _snap_sets = {}
                for sk in _snap_keys:
                    _snap_sets[sk] = set(deposit_long.loc[deposit_long['snapshot'] == sk, _dep_key].astype(str).str.strip())
                _overlap = _snap_sets[_snap_keys[0]]
                for sk in _snap_keys[1:]:
                    _overlap = _overlap & _snap_sets[sk]
                print(f"  Matched with acctid: {len(_overlap):,}")

        _wave_rows = []
        _seg_rows = []

        if len(_overlap) > 0:
            for mc, rc in zip(mail_cols, resp_cols):
                _label = mc.replace(' Mail', '')
                _mail_date = pd.to_datetime(_label, format='%b%y')

                _pre_snaps = [(sk, sd) for sk, sd in zip(_snap_keys, _snap_ts) if sd < _mail_date]
                _post_snaps = [(sk, sd) for sk, sd in zip(_snap_keys, _snap_ts)
                               if sd >= _mail_date + pd.DateOffset(months=1)]
                if not _pre_snaps or not _post_snaps:
                    continue

                _pre_snap = max(_pre_snaps, key=lambda x: x[1])
                _post_snap = min(_post_snaps, key=lambda x: x[1])

                # Get mailed account keys (map through ODDD join key)
                _mailed = rewards_df[mc].notna()
                _mailed_oddd_keys = set(rewards_df.loc[_mailed, _oddd_key].astype(str).str.strip())

                # Map ODDD keys to deposit keys
                # Build mapping: ODDD key -> deposit key for mailed accounts
                _pre_dl = deposit_long[deposit_long['snapshot'] == _pre_snap[0]].copy()
                _post_dl = deposit_long[deposit_long['snapshot'] == _post_snap[0]].copy()

                # The _join_key in deposit_long was built from acctid, and joined to rewards_df via _oddd_key
                # So _join_key in deposit_long should match _oddd_key values in rewards_df
                _pre_dl['_dk'] = _pre_dl[_dep_key].astype(str).str.strip()
                _post_dl['_dk'] = _post_dl[_dep_key].astype(str).str.strip()

                _pre_mailed = _pre_dl[_pre_dl['_dk'].isin(_mailed_oddd_keys)]
                _post_mailed = _post_dl[_post_dl['_dk'].isin(_mailed_oddd_keys)]

                if len(_pre_mailed) == 0 or len(_post_mailed) == 0:
                    continue

                _pre_dep = _pre_mailed.set_index('_dk')['depAmt365'].fillna(0) / 12
                _post_dep = _post_mailed.set_index('_dk')['depAmt365'].fillna(0) / 12

                _common = _pre_dep.index.intersection(_post_dep.index)
                if len(_common) < 5:
                    continue
                _pre_dep = _pre_dep.loc[_common]
                _post_dep = _post_dep.loc[_common]

                _wave_rows.append(_make_wave_row(
                    _label, len(_common), _pre_dep.median(), _post_dep.median(),
                    {'Pre Snap': _pre_snap[0], 'Post Snap': _post_snap[0]}))

                # Per-segment
                if rc in rewards_df.columns:
                    _resp_vals = rewards_df.loc[_mailed, rc]
                    _segments = _resp_vals.map(_parse_segment)
                    _acct_keys = rewards_df.loc[_mailed, _oddd_key].astype(str).str.strip()

                    for seg in sorted(_segments.dropna().unique()):
                        _seg_keys = set(_acct_keys[_segments == seg])
                        _seg_common = [k for k in _common if k in _seg_keys]
                        if len(_seg_common) < 5:
                            continue
                        _seg_rows.append(_make_wave_row(
                            _label, len(_seg_common),
                            _pre_dep.loc[_seg_common].median(),
                            _post_dep.loc[_seg_common].median(),
                            {'Segment': seg}))

                    # Non-responders
                    _nr_keys = set(_acct_keys[~_resp_vals.map(_is_success)])
                    _nr_common = [k for k in _common if k in _nr_keys]
                    if len(_nr_common) >= 5:
                        _seg_rows.append(_make_wave_row(
                            _label, len(_nr_common),
                            _pre_dep.loc[_nr_common].median(),
                            _post_dep.loc[_nr_common].median(),
                            {'Segment': 'Non-Responder'}))

        if _wave_rows:
            _wdf = pd.DataFrame(_wave_rows)
            for c in _wdf.columns:
                if _wdf[c].dtype in ('float64', 'float32'):
                    _wdf[c] = _wdf[c].round(1)

            _display_table(_wdf,
                f"Deposit Lift by Mailer ({SNAPSHOT_ORDER[0]} vs {SNAPSHOT_ORDER[-1]})  |  {DATASET_LABEL}")
            _make_chart(_wdf, "Deposit Lift: Pre vs Post Mailer",
                f"depAmt365/12 compared across snapshots  |  {DATASET_LABEL}")

            _avg = _wdf['Change $'].mean()
            _s = '+' if _avg >= 0 else ''
            print(f"  Average deposit change: {_s}${_avg:,.0f}/mo across {len(_wdf)} waves")

        if _seg_rows:
            _sdf = pd.DataFrame(_seg_rows)
            for c in _sdf.columns:
                if _sdf[c].dtype in ('float64', 'float32'):
                    _sdf[c] = _sdf[c].round(1)
            _display_table(_sdf, f"Deposit Lift by Segment  |  {DATASET_LABEL}")

            _winners = _sdf[(_sdf['Change $'] > 0) & (_sdf['Segment'] != 'Non-Responder')]
            if len(_winners) > 0:
                _best = _winners.sort_values('Change %', ascending=False).iloc[0]
                print(f"\n  Best segment: {_best['Segment']} at {_best['Mailer']}")
                print(f"    +${_best['Change $']:,.0f} ({_best['Change %']:+.1f}%), N={int(_best['N']):,}")

        if not _wave_rows:
            print("\n  Multi-snapshot: no mailer waves matched or 0 account overlap.")

    # =================================================================
    # SINGLE-SNAPSHOT SUPPLEMENT: DepAmt365 as baseline, DepAmt33 as recent
    # =================================================================
    _has_365 = 'depAmt365' in _acct.columns
    _has_33 = 'DepAmt33' in _acct.columns

    if _has_365 and _has_33:
        print(f"\n  === Single-Snapshot Supplement (365d baseline vs 33d recent) ===")

        # For any mailer in the last ~11 months:
        #   depAmt365/12 = avg monthly over full year (blends pre+post)
        #   DepAmt33 = most recent ~1 month of deposits
        # If mailer activated deposits, DepAmt33 should be higher than depAmt365/12.
        # This isn't a clean pre/post but it's directional evidence.

        if 'SNAPSHOT_ORDER' in dir() and len(SNAPSHOT_ORDER) > 0:
            _sc = SNAPSHOT_CONFIG[SNAPSHOT_ORDER[-1]]
            _snap_date = pd.Timestamp(year=_sc['sort_key'] // 100,
                                       month=_sc['sort_key'] % 100, day=15)
            _snap_label = _sc['label']
        else:
            _snap_date = pd.Timestamp.now()
            _snap_label = 'Latest'

        print(f"  Snapshot: {_snap_label}")
        print(f"  Comparing: depAmt365/12 (12mo avg) vs DepAmt33 (recent ~1mo)")

        _wave_rows = []
        _seg_rows = []

        for mc, rc in zip(mail_cols, resp_cols):
            _label = mc.replace(' Mail', '')
            _mail_date = pd.to_datetime(_label, format='%b%y')

            # Only include mailers that happened before the snapshot
            # and at least 33 days before it (so DepAmt33 is post-mailer)
            _days_since = (_snap_date - _mail_date).days
            if _days_since < 40 or _days_since > 365:
                continue

            _mailed = rewards_df[mc].notna()
            _mailed_idx = rewards_df.index[_mailed]
            _am = _acct.reindex(_mailed_idx).dropna(subset=['DepAmt33', 'depAmt365'])

            if len(_am) < 10:
                continue

            _baseline = _am['depAmt365'].fillna(0) / 12  # 12mo avg
            _recent = _am['DepAmt33'].fillna(0)            # recent ~1mo

            _wave_rows.append(_make_wave_row(
                _label, len(_am), _baseline.median(), _recent.median()))

            # Segments
            if rc in rewards_df.columns:
                _resp_vals = rewards_df.loc[_mailed, rc]
                _segments = _resp_vals.map(_parse_segment)

                for seg in sorted(_segments.dropna().unique()):
                    _seg_idx = _resp_vals.index[_segments == seg]
                    _sa = _am.reindex(_seg_idx).dropna(subset=['DepAmt33'])
                    if len(_sa) < 5:
                        continue
                    _sb = _sa['depAmt365'].fillna(0) / 12
                    _sr = _sa['DepAmt33'].fillna(0)
                    _seg_rows.append(_make_wave_row(
                        _label, len(_sa), _sb.median(), _sr.median(),
                        {'Segment': seg}))

                _nr_mask = _mailed & ~_resp_vals.map(_is_success)
                _nr_idx = rewards_df.index[_nr_mask]
                _nra = _am.reindex(_nr_idx).dropna(subset=['DepAmt33'])
                if len(_nra) >= 5:
                    _seg_rows.append(_make_wave_row(
                        _label, len(_nra),
                        (_nra['depAmt365'].fillna(0) / 12).median(),
                        _nra['DepAmt33'].fillna(0).median(),
                        {'Segment': 'Non-Responder'}))

        if _wave_rows:
            _wdf = pd.DataFrame(_wave_rows)
            for c in _wdf.columns:
                if _wdf[c].dtype in ('float64', 'float32'):
                    _wdf[c] = _wdf[c].round(1)

            _display_table(_wdf,
                f"Deposit Trend: 12mo Avg vs Recent (from {_snap_label})  |  {DATASET_LABEL}")

        if _seg_rows:
            _sdf = pd.DataFrame(_seg_rows)
            for c in _sdf.columns:
                if _sdf[c].dtype in ('float64', 'float32'):
                    _sdf[c] = _sdf[c].round(1)
            _display_table(_sdf,
                f"Deposit Trend by Segment: 12mo Avg vs Recent  |  {DATASET_LABEL}")

            _winners = _sdf[(_sdf['Change $'] > 0) & (_sdf['Segment'] != 'Non-Responder')]
            if len(_winners) > 0:
                _best = _winners.sort_values('Change %', ascending=False).iloc[0]
                print(f"\n  Best segment: {_best['Segment']} at {_best['Mailer']}")
                print(f"    +${_best['Change $']:,.0f} ({_best['Change %']:+.1f}%), N={int(_best['N']):,}")

        if not _wave_rows:
            print("  No mailers in the 40-365 day window before snapshot.")
